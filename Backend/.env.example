# ClarkPlayer environment configuration
# Copy this file to .env and adjust values for your deployment.
# WARNING: Never commit .env with real secrets to version control!

# ── Application ─────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/ClarkPlayer
DATABASE_ECHO=false

# ── Auth / JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Change this in production!  Use a long, random string.
JWT_SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── JWE (JSON Web Encryption) RSA Keys ──────────────────────────────────
# If empty, a new 2048-bit RSA key pair is generated on startup.
# JWE_PRIVATE_KEY_PEM=
# JWE_PUBLIC_KEY_PEM=

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SESSION_DB=0
REDIS_CACHE_DB=1
REDIS_RATELIMIT_DB=2

# ── File storage ────────────────────────────────────────────────────────
MEDIA_ROOT=./media
MAX_UPLOAD_SIZE_MB=500

# ── Backup ──────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_ENABLED=true

# ── CORS ────────────────────────────────────────────────────────────────
# Must be explicit when allow_credentials=True.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ── Google OIDC ───────────────────────────────────────────────────────
# Get these from Google Cloud Console > APIs & Services > Credentials
#
# Google Cloud Console setup (SPA flow):
#   Authorized JavaScript Origins: http://localhost:3000
#   Authorized Redirect URIs:      http://localhost:3000/auth/callback
#
# The frontend receives the code from Google and POSTs it to:
#   POST http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Resend transactional email ────────────────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_DEV=onboarding@resend.dev
RESEND_FROM_PROD=noreply@clarkplayer.app
RESEND_FROM=${RESEND_FROM_DEV}

# Email token TTL (tokens stored in Redis DB 0)
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# Frontend base URL (used to build links inside emails)
FRONTEND_URL=http://localhost:3000

# ── Music Metadata APIs ─────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET
GENIUS_ACCESS_TOKEN=YOUR_GENIUS_ACCESS_TOKEN
GENIUS_CLIENT_ACCESS_TOKEN=YOUR_GENIUS_CLIENT_ACCESS_TOKEN
LASTFM_API_KEY=YOUR_LASTFM_API_KEY
LASTFM_SHARED_SECRET=YOUR_LASTFM_SHARED_SECRET
