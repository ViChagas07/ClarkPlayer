{
  "name": "clarkplayer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "concurrently -n \"FRONTEND,BACKEND\" -c \"cyan,green\" \"npm run dev\" \"cd ../Backend && ./venv/Scripts/Activate.ps1 -Command uvicorn app.main:app --reload\"",
